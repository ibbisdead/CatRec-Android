    <string-array name="changelog_v090_items">
        <item>Screen recording with H.264 and H.265 (HEVC) codec support</item>
        <item>Rolling Clipper buffer (1–5 min, configurable) with seamless segment stitching</item>
        <item>Save Clip button appears instantly while Clipper is running</item>
        <item>Wide resolution selection for all aspect ratios, plus custom input</item>
        <item>Auto orientation tracking during recording</item>
        <item>Countdown timer before recording starts</item>
        <item>Keep-screen-on option during recording</item>
        <item>Audio recording: microphone, internal audio, or mixed</item>
        <item>Separate microphone track recording</item>
        <item>Advanced audio settings: bitrate, sample rate, channels, encoder</item>
        <item>Fixed stereo audio recording for stereo channel mode</item>
        <item>Fixed audio bitrate accuracy with CBR encoding</item>
        <item>Floating controls overlay: pause, stop, mute, screenshot</item>
        <item>Overlay available at all times, not just during recording</item>
        <item>Start recording or clipping directly from the overlay button</item>
        <item>One-tap authorize overlay recording — no repeated permission prompts</item>
        <item>Overlay X dismiss appears immediately on drag</item>
        <item>Camera overlay with live face-cam preview</item>
        <item>Watermark overlay with custom images, shape, opacity, and position</item>
        <item>Screenshots tab with format and quality settings</item>
        <item>Screenshots captured from the overlay camera button</item>
        <item>Accent color customization: presets, gradients, and hex input</item>
        <item>Dynamic theme — all UI elements follow the chosen accent color</item>
        <item>Performance mode toggle disables blur for lower-end devices</item>
        <item>Full settings reorganization (Controls, Video, Audio, Overlay…)</item>
        <item>Language support for 16 languages</item>
        <item>Fixed language preference persisting after app restart</item>
        <item>Recordings library with thumbnail previews</item>
        <item>In-app video trimmer</item>
        <item>Post-recording notification with thumbnail and quick actions</item>
        <item>Quick Settings tiles: CatRec Record and CatRec Clipper</item>
    </string-array>

    <!-- Changelog entries (v0.9.8) -->
    <string-array name="changelog_v098_items">
        <item>Watermark: default logo now matches your real app icon; snap-to-corner positions align correctly on all screen sizes</item>
        <item>Faster switching between bottom navigation tabs</item>
        <item>Minor bug fixes and stability improvements</item>
    </string-array>

    <!-- Changelog entries (v0.9.6) -->
    <string-array name="changelog_v096_items">
        <item>Resolved all remaining translation inconsistencies across all supported languages</item>
        <item>Redesigned the RECORD / CLIPPER mode selector for precise edge-to-edge fill and a more polished, professional look</item>
        <item>Fixed the recording status indicator — now a single persistent dot that pulses while recording or clipping, and stays static on standby</item>
    </string-array>

    <!-- Changelog entries (v0.9.5) -->
    <string-array name="changelog_v095_items">
        <item>Improved light theme contrast and styling</item>
        <item>Localization improvements across supported languages</item>
        <item>Optional, opt-in analytics to help diagnose issues and improve stability</item>
        <item>Corrected overlay shape rendering and watermark or logo cropping</item>
        <item>Restored reliable export of a separate microphone audio track</item>
        <item>Library indicator when a recording includes a separate mic track</item>
        <item>Quick-select duration presets for the Rolling Clipper buffer</item>
    </string-array>
