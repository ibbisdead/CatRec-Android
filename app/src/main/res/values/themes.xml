<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.CatRecScreenRecorcer" parent="android:Theme.Material.Light.NoActionBar">
        <!-- Pre-set before Compose/enableEdgeToEdge() renders its first frame,
             so Activity.recreate() (e.g. after a language change) never flashes
             white bars in the status-bar or navigation-bar regions. -->
        <item name="android:windowBackground">@color/cyber_black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    <style name="Theme.CatRec.Transparent" parent="android:Theme.Translucent.NoTitleBar">
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowNoTitle">true</item>
    </style>
</resources>