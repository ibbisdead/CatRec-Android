<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:baselineAligned="false"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="1dp">

    <LinearLayout
        android:id="@+id/btn_record"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/btn_record_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@string/notif_cc_record"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_record" />

        <TextView
            android:id="@+id/btn_record_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:alpha="0.7"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/notif_cc_record"
            android:textColor="#FF4444"
            android:textSize="10sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btn_screenshot"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/btn_screenshot_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@string/notif_cc_shot"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_screenshot" />

        <TextView
            android:id="@+id/btn_screenshot_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:alpha="0.7"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/notif_cc_shot"
            android:textColor="#FF4444"
            android:textSize="10sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/notif_ac_overlay"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/notif_ac_overlay_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@string/notif_cc_float"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_overlay" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:alpha="0.7"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/notif_cc_float"
            android:textColor="#FF4444"
            android:textSize="10sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/notif_ac_home"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@string/notif_cc_home"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_home" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:alpha="0.7"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/notif_cc_home"
            android:textColor="#FF4444"
            android:textSize="10sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/notif_ac_exit"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@string/notif_cc_close"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_exit" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:alpha="0.7"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/notif_cc_close"
            android:textColor="#FF4444"
            android:textSize="10sp" />
    </LinearLayout>
</LinearLayout>
