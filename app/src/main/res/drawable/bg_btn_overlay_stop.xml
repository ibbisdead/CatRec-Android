<?xml version="1.0" encoding="utf-8"?>
<!--
  Stop button — oval with a soft red ring + deeper red fill, plus a vivid
  red ripple so the press state feels distinct and energetic.
-->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#80FF5252">

    <!-- Ripple clipping mask (oval) -->
    <item android:id="@android:id/mask">
        <shape android:shape="oval">
            <solid android:color="#FFFFFFFF" />
        </shape>
    </item>

    <!-- Resting state: red-tinted fill + subtle ring -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#33E53935" />
            <stroke
                android:width="1.5dp"
                android:color="#66E53935" />
        </shape>
    </item>

</ripple>
