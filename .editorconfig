root = true

[*.{kt,kts}]
indent_style = space
indent_size = 4
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true
# Namespace uses underscore (catrec_screenrecorcer); ktlint forbids that by default.
ktlint_standard_package-name = disabled
# Compose: @Composable uses PascalCase; allow wildcard layout imports; long lines in services.
ktlint_standard_function-naming = disabled
ktlint_standard_property-naming = disabled
ktlint_standard_filename = disabled
ktlint_standard_no-wildcard-imports = disabled
ktlint_standard_max-line-length = disabled
# CatRecIcons uses _paw for val Paw (capital P); ktlint expects strict _foo/foo pairing.
ktlint_standard_backing-property-naming = disabled

[*.{xml,yml,yaml}]
indent_style = space
indent_size = 4
